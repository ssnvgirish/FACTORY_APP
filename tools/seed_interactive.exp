# Scrap Writing Efficiency
send "INSERT INTO scrap_writing_efficiency (date, machine_number, shift, submitted_at, shift_end_time, score, operator_id, \"timestamp\") VALUES ('2025-07-14', 'Pulverizer 1', 'Day Shift', '2025-07-14T17:30:00Z', '2025-07-14T18:00:00Z', 5, 'op-5', NOW()), ('2025-07-12', 'Pulverizer 2', 'Night Shift', '2025-07-13T05:45:00Z', '2025-07-13T06:00:00Z', 4, 'op-6', NOW()), ('2025-07-10', 'Pulverizer 1', 'Day Shift', '2025-07-10T18:15:00Z', '2025-07-10T18:00:00Z', 3, 'op-5', NOW());\r"
