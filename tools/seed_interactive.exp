# Scrap Production Weight Reports
send "INSERT INTO scrap_production_weight_report (date, machine_number, shift, total_production_weight, maintenance_weight, total_weight, target_weight, efficiency_percentage, created_by, \"timestamp\") VALUES ('2025-07-14', 'Pulverizer 1', 'Day Shift', 450.0, 125.0, 575.0, 800.0, 71.88, 'op-5', NOW()), ('2025-07-12', 'Pulverizer 2', 'Night Shift', 525.0, 87.5, 612.5, 800.0, 76.56, 'op-6', NOW()), ('2025-07-10', 'Pulverizer 1', 'Day Shift', 380.0, 150.0, 530.0, 800.0, 66.25, 'op-5', NOW()), ('2025-07-08', 'Pulverizer 3', 'Night Shift', 600.0, 100.0, 700.0, 800.0, 87.5, 'op-6', NOW());\r"
